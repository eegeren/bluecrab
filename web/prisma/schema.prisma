generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostType {
  TEXT
  IMAGE
  LINK
  POLL
}

enum PostMode {
  DISCUSSION
  FEEDBACK
  ROAST
  SHOWCASE
}

enum TemplateType {
  GENERAL_DISCUSSION
  STARTUP_IDEA
  SAAS_FEEDBACK
  BUILD_IN_PUBLIC
  GROWTH_QUESTION
}

enum MemberRole {
  MEMBER
  MODERATOR
  OWNER
}

enum CommunityType {
  PUBLIC
  RESTRICTED
  PRIVATE
}

enum ModerationState {
  VISIBLE
  PENDING
  REMOVED
  APPROVED
}

enum ReportReason {
  SPAM
  HARASSMENT
  RULE_BREAK
  MISINFORMATION
  NSFW
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
  ACTIONED
}

enum NotificationType {
  POST_REPLY
  COMMENT_REPLY
  COMMENT_MENTION
  MOD_ACTION
  REPORT_UPDATE
  MILESTONE
  ONBOARDING
}

enum FlairColor {
  SLATE
  SKY
  EMERALD
  AMBER
  ROSE
}

enum SavedItemType {
  POST
  COMMENT
}

enum ModerationActionType {
  APPROVE_POST
  REMOVE_POST
  LOCK_POST
  UNLOCK_POST
  STICKY_POST
  UNSTICKY_POST
  APPROVE_COMMENT
  REMOVE_COMMENT
  LOCK_COMMENT
  UNLOCK_COMMENT
  UPDATE_RULES
  UPDATE_SETTINGS
  BAN_USER
  UNBAN_USER
}

enum AuditLogType {
  ADMIN_REVIEW
  REPORT_REVIEW
  FEATURE_COMMUNITY
  FEATURE_POST
  USER_BAN
  USER_UNBAN
}

enum ProjectStage {
  IDEA
  MVP
  LAUNCHING
  GROWING
  PROFITABLE
}

enum ReputationCategory {
  SAAS_BUILDER
  AI_DEVELOPER
  GROWTH_EXPERT
  INDIE_HACKER
}

model User {
  id                        String                   @id @default(cuid())
  username                  String                   @unique
  email                     String                   @unique
  passwordHash              String
  bio                       String                   @default("")
  avatar                    String                   @default("")
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  sessions                  Session[]
  preferences               UserPreference?
  communities               Community[]              @relation("CommunityCreator")
  memberships               CommunityMember[]
  approvedCommunities       ApprovedUser[]
  bannedCommunities         BannedUser[]
  posts                     Post[]
  comments                  Comment[]
  drafts                    PostDraft[]
  postVotes                 PostVote[]
  commentVotes              CommentVote[]
  savedItems                SavedItem[]
  hiddenPosts               HiddenPost[]
  reports                   Report[]
  receivedNotifications     Notification[]           @relation("NotificationRecipient")
  actorNotifications        Notification[]           @relation("NotificationActor")
  moderationActions         ModerationAction[]       @relation("ModerationActor")
  moderatorNotesAbout       CommunityModeratorNote[] @relation("ModeratorNoteSubject")
  moderatorNotesWritten     CommunityModeratorNote[] @relation("ModeratorNoteAuthor")
  adminAuditLogs            AdminAuditLog[]
  projects                  Project[]
  reputationEntries         UserReputation[]
}

model UserPreference {
  id                           String   @id @default(cuid())
  userId                       String   @unique
  theme                        String   @default("dark")
  emailNotifications           Boolean  @default(true)
  pushNotifications            Boolean  @default(true)
  showNsfw                     Boolean  @default(false)
  showSpoilers                 Boolean  @default(true)
  publicActivity               Boolean  @default(true)
  compactMode                  Boolean  @default(false)
  communityDigest              Boolean  @default(true)
  allowPersonalizedSuggestions Boolean  @default(true)
  onboardingCompleted          Boolean  @default(false)
  interests                    String[]
  hideProfileNudge             Boolean  @default(false)
  user                         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Community {
  id                     String                   @id @default(cuid())
  name                   String
  slug                   String                   @unique
  description            String
  avatar                 String                   @default("")
  banner                 String                   @default("")
  memberCount            Int                      @default(1)
  activeCount            Int                      @default(0)
  category               String                   @default("General")
  type                   CommunityType            @default(PUBLIC)
  postPermission         String                   @default("members")
  commentPermission      String                   @default("members")
  allowTextPosts         Boolean                  @default(true)
  allowImagePosts        Boolean                  @default(true)
  allowLinkPosts         Boolean                  @default(true)
  allowPollPosts         Boolean                  @default(false)
  archiveOldPosts        Boolean                  @default(false)
  requirePostApproval    Boolean                  @default(false)
  isDiscoverable         Boolean                  @default(true)
  isFeatured             Boolean                  @default(false)
  featuredLabel          String                   @default("")
  welcomeMessage         String                   @default("")
  createdById            String
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  createdBy              User                     @relation("CommunityCreator", fields: [createdById], references: [id], onDelete: Cascade)
  rules                  CommunityRule[]
  flairs                 CommunityFlair[]
  automodRules           AutoModerationRule[]
  approvedUsers          ApprovedUser[]
  bannedUsers            BannedUser[]
  members                CommunityMember[]
  moderatorNotes         CommunityModeratorNote[]
  moderationActions      ModerationAction[]
  posts                  Post[]
  drafts                 PostDraft[]

  @@index([createdById])
  @@index([category, memberCount(sort: Desc)])
}

model CommunityRule {
  id          String    @id @default(cuid())
  communityId String
  title       String
  description String
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId, position])
}

model CommunityFlair {
  id               String    @id @default(cuid())
  communityId      String
  label            String
  color            FlairColor @default(SKY)
  textColor        String    @default("#e6f8ff")
  backgroundColor  String    @default("#0f172a")
  modOnly          Boolean   @default(false)
  allowUserSelect  Boolean   @default(true)
  createdAt        DateTime  @default(now())
  community        Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  posts            Post[]

  @@index([communityId])
}

model AutoModerationRule {
  id               String    @id @default(cuid())
  communityId      String
  name             String
  keyword          String?
  blockedDomain    String?
  action           String    @default("report")
  isEnabled        Boolean   @default(true)
  createdAt        DateTime  @default(now())
  community        Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
}

model ApprovedUser {
  id          String    @id @default(cuid())
  userId      String
  communityId String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
}

model BannedUser {
  id            String    @id @default(cuid())
  userId        String
  communityId   String
  reason        String    @default("")
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community     Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
}

model CommunityMember {
  id            String      @id @default(cuid())
  userId        String
  communityId   String
  role          MemberRole  @default(MEMBER)
  userFlair     String      @default("")
  joinedAt      DateTime    @default(now())
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  community     Community   @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
  @@index([communityId])
}

model Post {
  id               String            @id @default(cuid())
  title            String
  body             String?
  type             PostType
  postMode         PostMode          @default(DISCUSSION)
  templateType     TemplateType      @default(GENERAL_DISCUSSION)
  topicCategory    ReputationCategory @default(INDIE_HACKER)
  structuredPostData Json?
  aiSummary        Json?
  aiSummaryUpdatedAt DateTime?
  imageUrl         String?
  linkUrl          String?
  pollOptions      String[]
  authorId         String
  communityId      String
  projectId        String?
  flairId          String?
  score            Int               @default(0)
  hotScore         Float             @default(0)
  commentCount     Int               @default(0)
  isNsfw           Boolean           @default(false)
  isSpoiler        Boolean           @default(false)
  isLocked         Boolean           @default(false)
  isStickied       Boolean           @default(false)
  isRemoved        Boolean           @default(false)
  isDeleted        Boolean           @default(false)
  moderationState  ModerationState   @default(VISIBLE)
  isPromoted       Boolean           @default(false)
  promotedLabel    String            @default("")
  editedAt         DateTime?
  approvedAt       DateTime?
  crosspostPostId  String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  author           User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  community        Community         @relation(fields: [communityId], references: [id], onDelete: Cascade)
  project          Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  flair            CommunityFlair?   @relation(fields: [flairId], references: [id], onDelete: SetNull)
  crosspostPost    Post?             @relation("CrosspostRelation", fields: [crosspostPostId], references: [id], onDelete: SetNull)
  crossposts       Post[]            @relation("CrosspostRelation")
  votes            PostVote[]
  comments         Comment[]
  reports          Report[]
  savedItems       SavedItem[]
  hiddenBy         HiddenPost[]
  moderationActions ModerationAction[]
  notifications    Notification[]
  drafts           PostDraft[]

  @@index([communityId, createdAt(sort: Desc)])
  @@index([score(sort: Desc)])
  @@index([hotScore(sort: Desc)])
  @@index([moderationState, createdAt(sort: Desc)])
  @@index([topicCategory, score(sort: Desc)])
}

model PostDraft {
  id          String    @id @default(cuid())
  userId      String
  communityId String?
  postId      String?
  title       String
  body        String?
  type        PostType  @default(TEXT)
  imageUrl    String?
  linkUrl     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)
  post        Post?     @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt(sort: Desc)])
}

model PostVote {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  value     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model Comment {
  id               String            @id @default(cuid())
  body             String
  authorId         String
  postId           String
  parentId         String?
  score            Int               @default(0)
  isLocked         Boolean           @default(false)
  isRemoved        Boolean           @default(false)
  isDeleted        Boolean           @default(false)
  moderationState  ModerationState   @default(VISIBLE)
  editedAt         DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  author           User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post             Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent           Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies          Comment[]         @relation("CommentReplies")
  votes            CommentVote[]
  reports          Report[]
  savedItems       SavedItem[]
  notifications    Notification[]
  moderationActions ModerationAction[]

  @@index([postId, createdAt(sort: Asc)])
  @@index([parentId])
  @@index([moderationState, createdAt(sort: Desc)])
}

model CommentVote {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  value     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model SavedItem {
  id         String        @id @default(cuid())
  userId     String
  type       SavedItemType
  postId     String?
  commentId  String?
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       Post?         @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment    Comment?      @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model HiddenPost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Report {
  id            String       @id @default(cuid())
  userId        String
  postId        String?
  commentId     String?
  reason        ReportReason
  details       String       @default("")
  status        ReportStatus @default(OPEN)
  createdAt     DateTime     @default(now())
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  post          Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment       Comment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([commentId])
  @@index([status, createdAt(sort: Desc)])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  actorId     String?
  postId      String?
  commentId   String?
  type        NotificationType
  body        String
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  user        User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor       User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  post        Post?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment     Comment?         @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
}

model ModerationAction {
  id           String                @id @default(cuid())
  communityId  String
  actorId      String
  postId       String?
  commentId    String?
  actionType   ModerationActionType
  note         String                @default("")
  createdAt    DateTime              @default(now())
  community    Community             @relation(fields: [communityId], references: [id], onDelete: Cascade)
  actor        User                  @relation("ModerationActor", fields: [actorId], references: [id], onDelete: Cascade)
  post         Post?                 @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment      Comment?              @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([communityId, createdAt(sort: Desc)])
}

model CommunityModeratorNote {
  id            String    @id @default(cuid())
  communityId   String
  authorId      String
  subjectUserId String
  body          String
  createdAt     DateTime  @default(now())
  community     Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author        User      @relation("ModeratorNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  subjectUser   User      @relation("ModeratorNoteSubject", fields: [subjectUserId], references: [id], onDelete: Cascade)
}

model AdminAuditLog {
  id          String       @id @default(cuid())
  actorUserId String?
  type        AuditLogType
  targetId    String       @default("")
  summary     String
  createdAt   DateTime     @default(now())
  actor       User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([type, createdAt(sort: Desc)])
}

model UserReputation {
  id          String             @id @default(cuid())
  userId      String
  category    ReputationCategory
  score       Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

model Project {
  id          String         @id @default(cuid())
  userId      String
  name        String
  slug        String         @unique
  description String
  stage       ProjectStage   @default(IDEA)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts       Post[]
  updates     ProjectUpdate[]

  @@index([userId, createdAt(sort: Desc)])
}

model ProjectUpdate {
  id          String      @id @default(cuid())
  projectId   String
  title       String
  content     String
  createdAt   DateTime    @default(now())
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc)])
}
